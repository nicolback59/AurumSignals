# ============================================================
# NQ Signal Pro — Environment Variables
# Copy this file to .env for local development.
# On Render, set these in the Environment tab (never commit .env).
# ============================================================

# Database
# SQLite (default for local dev — no setup needed)
DATABASE_URL=sqlite:///./signals.db

# PostgreSQL (Render managed DB — use the connection string from Render dashboard)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ────────────────────────────────────────────────
# Random secret that TradingView must include in the alert JSON body.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change_me_to_a_random_secret

# ── CORS ────────────────────────────────────────────────────
# In production, restrict to your Squarespace domain:
# CORS_ORIGINS=https://yoursite.squarespace.com,https://yoursite.com
CORS_ORIGINS=*

# ── Alert destinations (all optional) ───────────────────────
# Discord: right-click a channel → Integrations → Webhooks → Copy URL
DISCORD_WEBHOOK_URL=

# Slack: create an Incoming Webhook at api.slack.com/apps
SLACK_WEBHOOK_URL=

# Email via SendGrid (create a free account at sendgrid.com)
SENDGRID_API_KEY=
ALERT_EMAIL_TO=your@email.com
ALERT_EMAIL_FROM=alerts@yourdomain.com

# ── Behaviour ────────────────────────────────────────────────
PAPER_TRADING_ENABLED=true
TRADE_CONTRACTS=1
MAX_OPEN_TRADES_PER_INSTRUMENT=1

LOG_LEVEL=INFO

# How often the Python engine scans for signals (minutes)
SCAN_INTERVAL_MINUTES=5
