# Aurum Signals — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git

NODE_ENV=production

# ── Scanner ───────────────────────────────────────────────────────────────────
SCAN_INTERVAL=30
SCANNER_LOG_LEVEL=signal
DAILY_SIGNAL_CAP=20
SCANNER_DUPLICATE_GUARD_MIN=5
SCANNER_SYMBOL=NQ=F
SCANNER_SYMBOL_MGC=GC=F

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/opt/aurumsignals/aurum.db

# ── Notifications ─────────────────────────────────────────────────────────────
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=your-ntfy-topic-here
NTFY_TOKEN=

# ── Data Feed ─────────────────────────────────────────────────────────────────
# Optional: Polygon.io API key for reliable candle data (replaces Yahoo Finance)
# Get one at polygon.io — Basic plan is $29/mo
# POLYGON_API_KEY=

# ── Optional: Tradovate real-time feed ───────────────────────────────────────
# TRADOVATE_USERNAME=
# TRADOVATE_CID=
# TRADOVATE_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Webhook security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Public URL of the app — used for password reset links (no trailing slash)
SITE_URL=https://your-app.onrender.com

# ── Email (optional — for password reset emails) ──────────────────────────────
# Without these, reset tokens are logged to console only (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
