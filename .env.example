# Aurum Signals — environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file (created automatically if absent).
# On Render.com use the persistent volume mount: /data/signals.db
DATABASE_PATH=./signals.db

# ── Push notifications (ntfy.sh) ──────────────────────────────────────────────
# ntfy server base URL (default public server shown; self-host for private use)
NTFY_URL=https://ntfy.sh
# ntfy topic name (keep this private — anyone with the topic name can subscribe)
NTFY_TOPIC=your-private-topic-name
# Bearer token for authenticated ntfy topics (leave blank if topic is public)
NTFY_TOKEN=

# ── Webhook security ──────────────────────────────────────────────────────────
# Secret used to verify inbound TradingView / webhook POST signatures.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ── Live data feed — Tradovate (optional) ─────────────────────────────────────
# If all three are set, the Tradovate WebSocket feed is used instead of Yahoo.
TRADOVATE_USERNAME=
TRADOVATE_CID=
TRADOVATE_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Render/Droplet split architecture ─────────────────────────────────────────
# Set on the DROPLET (server.js) to allow CORS from the Render frontend.
# e.g. https://aurum-signals-frontend.onrender.com
FRONTEND_URL=

# Set on RENDER (render-server.js) to point at the Droplet backend.
# e.g. http://165.232.1.2:3000
DROPLET_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Public URL of the app — used for password reset links (no trailing slash)
SITE_URL=https://your-app.onrender.com

# ── Email (optional — for password reset emails) ──────────────────────────────
# Without these, reset tokens are logged to console only (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
